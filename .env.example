# Environment variables for UP Rainfall Predictor
# ─────────────────────────────────────────────────────────────
# Copy this file to  .env  and fill in real values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────

# Flask secret key (change this to a long random string in production)
SECRET_KEY=change-me-to-something-random-and-secret

# Flask debug mode  (set to 'false' in production)
FLASK_DEBUG=true

# Port the Flask server listens on
PORT=5000

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Model version tag shown in DB records and /health endpoint
MODEL_VERSION=1.0.0
